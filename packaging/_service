<!--
  OBS source service chain for the `beam` package.

  Tracks the tip of `main` on GitHub. Releases are cut by tagging `main` with a plain
  version number (e.g. `0.2.0`, no leading "v") and pushing the tag; the repo's GitHub Actions
  workflow (.github/workflows/publish-obs.yml) then calls OBS's `trigger/runservice` endpoint,
  which re-runs this exact service chain against the then-current tip of `main`.

  obs_scm    - clones the repo (checkout lands in a `Beam/` directory, matching the GitHub
               repo name) and produces the beam.obscpio/.obsinfo OBS-native source pair;
               version is derived from the nearest reachable git tag via versionformat.
  set_version - rewrites beam.spec's Version: field to match what obs_scm detected.
  cargo_vendor - vendors every crates.io dependency found in the `Beam/` checkout into
               vendor.tar.zst, so the RPM build has no network access.
-->
<services>
  <service name="obs_scm" mode="manual">
    <param name="url">https://github.com/britors/Beam.git</param>
    <param name="scm">git</param>
    <param name="revision">main</param>
    <param name="versionformat">@PARENT_TAG@</param>
    <param name="filename">beam</param>
  </service>
  <service name="set_version" mode="manual" />
  <service name="cargo_vendor" mode="manual">
    <param name="src">Beam</param>
    <param name="compression">zst</param>
    <param name="update">true</param>
  </service>
</services>
